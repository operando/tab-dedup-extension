{
  "manifest_version": 3,
  "name": "Tab Dedup",
  "version": "1.0.0",
  "description": "開いているタブの重複URLを検出し、1つだけ残して残りを自動で閉じます。",
  "permissions": ["tabs", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Dedup"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
